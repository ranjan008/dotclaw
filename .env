# DISCOM OT Intelligence POC — Environment Configuration

# Mock OT API Server
OT_API_BASE=http://localhost:5000
OT_API_TOKEN=OT-POC-TOKEN-2026

# OpenClaw Webhook
OPENCLAW_WEBHOOK_URL=http://localhost:18789/hooks/agent
OPENCLAW_WEBHOOK_TOKEN=WEBHOOK-SECRET-2026
OPENCLAW_AGENT_ID=discom-ot-agent

# WhatsApp delivery target (test number)
WHATSAPP_TEST_NUMBER=+919999999999

# ── RBAC Gateway (rbac_gateway.py) ──────────────────────────────────────────
# Port the RBAC gateway listens on
RBAC_GATEWAY_PORT=8080

# Token for dev / non-Meta clients posting to /wa/webhook
RBAC_GATEWAY_TOKEN=RBAC-GW-TOKEN-2026

# SQLite database path (default: ./rbac.db)
# RBAC_DB_PATH=/var/dotclaw/rbac.db

# WhatsApp webhook verification token (must match Meta dashboard)
WA_VERIFY_TOKEN=dotclaw-verify-2026

# ── Production WhatsApp credentials (set in prod, leave blank for PoC) ──────
# WHATSAPP_API_TOKEN=<Meta Graph API bearer token>
# WHATSAPP_PHONE_NUMBER_ID=<phone number ID from Meta dashboard>
# WHATSAPP_APP_SECRET=<app secret for HMAC signature verification>
